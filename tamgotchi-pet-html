  <div style="display:flex;justify-content:center;align-items:center;gap:4px;margin-top:2px">
    <div style="display:grid;grid-template-columns:28px 28px 28px;grid-template-rows:18px 18px;gap:2px">
      <div></div>
      <button id="nhUp" style="background:#1a2a0f;color:#8fa133;border:1px solid #000;font-size:9px;padding:0">▲</button>
      <div></div>
      <button id="nhLeft" style="background:#1a2a0f;color:#8fa133;border:1px solid #000;font-size:9px;padding:0">◄</button>
      <button id="nhDown" style="background:#1a2a0f;color:#8fa133;border:1px solid #000;font-size:9px;padding:0">▼</button>
      <button id="nhRight" style="background:#1a2a0f;color:#8fa133;border:1px solid #000;font-size:9px;padding:0">►</button>
    </div>
    <button id="nhShop" style="background:#5a3a0f;color:#ffcc66;border:2px solid #000;font-size:8px;padding:4px 6px;height:38px">🛒<br>LOJA</button>
  </div>
  <div id="nhLog" style="font-size:6px;color:#5a6d1f;text-align:center;height:8px;margin-top:1px;overflow:hidden"></div>`;

  const c = document.getElementById('nh'), ctx = c.getContext('2d');
  const cols=15, rows=11, tile=16;
  const beep = (f,d=0.05)=>{try{const a=new (window.AudioContext||window.webkitAudioContext)();const o=a.createOscillator();const g=a.createGain();o.type='square';o.frequency.value=f;o.connect(g);g.connect(a.destination);g.gain.setValueAtTime(0.1,a.currentTime);g.gain.exponentialRampToValueAtTime(0.01,a.currentTime+d);o.start();o.stop(a.currentTime+d);}catch(e){}};
  
  let save = JSON.parse(localStorage.getItem('dungeon_save')||'null');
  let level = save?.level||1;
  let player = save?.player||{x:1,y:1,hp:12,maxHp:12,atk:1,weapon:null,hunger:100,vision:3,xp:0,inv:[]};
  let gold = save?.gold||0;
  let gameOver=false;
  
  let map=[], visible=[], explored=[], monsters=[], items=[];
  const log = (t)=>{document.getElementById('nhLog').textContent=t; setTimeout(()=>{if(document.getElementById('nhLog').textContent===t)document.getElementById('nhLog').textContent='';},1200);};
  
  const monsterTypes = {
    r:{hp:3,atk:1,name:'rato',c:'#a65'},
    b:{hp:2,atk:1,name:'morcego',c:'#68a'},
    s:{hp:4,atk:1,name:'slime',c:'#5a5'},
    d:{hp:5,atk:2,name:'cachorro',c:'#964'},
    o:{hp:6,atk:2,name:'orc',c:'#845'},
    k:{hp:5,atk:2,name:'kobold',c:'#a84'},
    D:{hp:18,atk:4,name:'DRAGÃO',c:'#d22'}
  };
  
  function genLevel(lv){
    map=Array(rows).fill().map(()=>Array(cols).fill(1));
    visible=Array(rows).fill().map(()=>Array(cols).fill(0));
    explored=Array(rows).fill().map(()=>Array(cols).fill(0));
    for(let y=1;y<rows-1;y++)for(let x=1;x<cols-1;x++)map[y][x]=0;
    for(let i=0;i<cols;i++){map[0][i]=1;map[rows-1][i]=1}
    for(let i=0;i<rows;i++){map[i][0]=1;map[i][cols-1]=1}
    for(let i=0;i<10+lv*2;i++){const px=2+Math.floor(Math.random()*(cols-4)),py=2+Math.floor(Math.random()*(rows-4));if(Math.random()<0.6)map[py][px]=1;}
    for(let i=0;i<3+lv;i++){let tx,ty;do{tx=1+Math.floor(Math.random()*(cols-2));ty=1+Math.floor(Math.random()*(rows-2));}while(map[ty][tx]!==0);map[ty][tx]=3;}
    map[rows-2][cols-2]=2;
    player.x=1;player.y=1;
    monsters=[];
    const mCount = 4+lv*2;
    const types = lv===1?['r','b','s']:lv===2?['d','o','k','s']:['o','k','d','s'];
    for(let i=0;i<mCount;i++){
      let mx,my;do{mx=2+Math.floor(Math.random()*(cols-4));my=2+Math.floor(Math.random()*(rows-4));}while(map[my][mx]!==0||(Math.abs(mx-player.x)+Math.abs(my-player.y)<3));
      const t=types[Math.floor(Math.random()*types.length)];
      monsters.push({x:mx,y:my,type:t,...JSON.parse(JSON.stringify(monsterTypes[t])),hp:monsterTypes[t].hp+lv});
    }
    if(lv===3){monsters.push({x:cols-3,y:rows-3,type:'D',...JSON.parse(JSON.stringify(monsterTypes.D)),hp:22});}
    items=[];
    const itemPool = ['potion_heal','potion_heal','potion_speed','potion_vision','food','dagger','gold','gold','gold'];
    for(let i=0;i<8+lv;i++){
      let ix,iy;do{ix=1+Math.floor(Math.random()*(cols-2));iy=1+Math.floor(Math.random()*(rows-2));}while(map[iy][ix]!==0);
      const it=itemPool[Math.floor(Math.random()*itemPool.length)];
      items.push({x:ix,y:iy,type:it,val:it==='gold'?5+Math.floor(Math.random()*15):0});
    }
    if(lv===3){items.push({x:cols-4,y:2,type:'amulet'});items.push({x:2,y:rows-3,type:'sword'});}
    updateVision();
  }
  
  function updateVision(){
    visible=visible.map(r=>r.map(()=>0));
    for(let dy=-player.vision;dy<=player.vision;dy++){
      for(let dx=-player.vision;dx<=player.vision;dx++){
        const nx=player.x+dx,ny=player.y+dy;
        if(nx<0||ny<0||nx>=cols||ny>=rows)continue;
        if(Math.abs(dx)+Math.abs(dy)>player.vision+1)continue;
        let blocked=false;
        const steps=Math.max(Math.abs(dx),Math.abs(dy));
        for(let s=1;s<steps;s++){const ix=player.x+Math.round(dx*s/steps),iy=player.y+Math.round(dy*s/steps);if(map[iy][ix]===1){blocked=true;break;}}
        if(!blocked){visible[ny][nx]=1;explored[ny][nx]=1;}
      }
    }
  }
  
  function draw(){
    ctx.fillStyle='#000';ctx.fillRect(0,0,240,176);
    ctx.font='12px monospace';ctx.textBaseline='top';
    for(let y=0;y<rows;y++){
      for(let x=0;x<cols;x++){
        if(!explored[y][x])continue;
        const px=x*tile,py=y*tile;
        const vis=visible[y][x];
        if(!vis){ctx.fillStyle='#1a2a0f';ctx.fillRect(px,py,tile,tile);continue;}
        if(map[y][x]===1){ctx.fillStyle='#1a2a0f';ctx.fillRect(px,py,tile,tile);ctx.fillStyle='#5a6d1f';ctx.fillText('#',px+4,py+2);}
        else if(map[y][x]===2){ctx.fillStyle='#c8d6a8';ctx.fillRect(px,py,tile-1,tile-1);ctx.fillStyle='#1a2a0f';ctx.fillText('>',px+4,py+2);}
        else if(map[y][x]===3){ctx.fillStyle='#c8d6a8';ctx.fillRect(px,py,tile-1,tile-1);ctx.fillStyle='#a00';ctx.fillText('^',px+4,py+2);}
        else{ctx.fillStyle='#c8d6a8';ctx.fillRect(px,py,tile-1,tile-1);}
      }
    }
    items.forEach(it=>{if(!visible[it.y][it.x])return;const ch=it.type==='gold'?'$':it.type==='amulet'?'☥':it.type.includes('potion')?'!':it.type==='food'?'%':'/';ctx.fillStyle='#1a2a0f';ctx.fillText(ch,it.x*tile+4,it.y*tile+2);});
    monsters.forEach(m=>{if(!visible[m.y][m.x])return;ctx.fillStyle=m.c;ctx.fillRect(m.x*tile+2,m.y*tile+2,tile-4,tile-4);ctx.fillStyle='#000';ctx.fillText(m.type,m.x*tile+4,m.y*tile+2);});
    ctx.fillStyle='#0a3';ctx.fillRect(player.x*tile+2,player.y*tile+2,tile-4,tile-4);ctx.fillStyle='#fff';ctx.fillText('@',player.x*tile+4,player.y*tile+2);
    
    document.getElementById('nhHp').textContent=player.hp;
    document.getElementById('nhHun').textContent=player.hunger;
    document.getElementById('nhLv').textContent=level;
    document.getElementById('nhAtk').textContent=player.atk+(player.weapon?player.weapon.atk:0);
    document.getElementById('nhGold').textContent=gold;
    const invDiv=document.getElementById('nhInv');invDiv.innerHTML='';
    for(let i=0;i<6;i++){const b=document.createElement('button');b.style.cssText='background:#1a2a0f;color:#8fa133;border:1px solid #000;font-size:8px;padding:0;height:14px';const it=player.inv[i];b.textContent=it?(it.type==='potion_heal'?'!':it.type==='potion_speed'?'⚡':it.type==='potion_vision'?'👁':it.type==='food'?'%':it.type==='dagger'?'†':it.type==='sword'?'‡':'?'):'·';b.onclick=()=>useItem(i);invDiv.appendChild(b);}
  }
  
  function useItem(i){
    const it=player.inv[i];if(!it)return;
    if(it.type==='potion_heal'){player.hp=Math.min(player.maxHp,player.hp+6);log('Curou +6');beep(600);}
    else if(it.type==='potion_speed'){player.vision=Math.min(5,player.vision+1);log('Visão +1');beep(800);}
    else if(it.type==='potion_vision'){explored=explored.map(r=>r.map(()=>1));log('Mapa revelado');beep(1000);}
    else if(it.type==='food'){player.hunger=Math.min(100,player.hunger+30);state.fome=Math.min(100,state.fome+15);log('Comeu');beep(400);}
    else if(it.type==='dagger'||it.type==='sword'){player.weapon=it;log('Equipou '+it.type);beep(500);}
    player.inv.splice(i,1);draw();saveGame();
  }
  
  function move(dx,dy){
    if(gameOver)return;
    const nx=player.x+dx,ny=player.y+dy;
    if(nx<0||ny<0||nx>=cols||ny>=rows||map[ny][nx]===1){beep(200);return;}
    const mi=monsters.findIndex(m=>m.x===nx&&m.y===ny);
    if(mi>=0){const m=monsters[mi];const dmg=player.atk+(player.weapon?player.weapon.atk:0)+Math.floor(player.xp/3);m.hp-=dmg;beep(300);log('Atacou '+m.name);if(m.hp<=0){monsters.splice(mi,1);player.xp++;gold+=2+level;if(Math.random()<0.4)items.push({x:nx,y:ny,type:'gold',val:5});if(Math.random()<0.2)items.push({x:nx,y:ny,type:'potion_heal'});log('Matou!');beep(700);}else{player.hp-=m.atk;log('Levou '+m.atk);beep(250);if(player.hp<=0){endGame(false);return;}}draw();return;}
    
    player.x=nx;player.y=ny;player.hunger=Math.max(0,player.hunger-1);if(player.hunger===0&&Math.random()<0.3){player.hp--;log('Fome!');}
    if(map[ny][nx]===3){player.hp-=2;map[ny][nx]=0;log('ARMADILHA -2');beep(150);if(player.hp<=0){endGame(false);return;}}
    const ii=items.findIndex(it=>it.x===nx&&it.y===ny);
    if(ii>=0){const it=items[ii];if(it.type==='gold'){gold+=it.val;log('+'+it.val+'$');beep(900);}else if(it.type==='amulet'){endGame(true);return;}else if(player.inv.length<6){player.inv.push(it);log('Pegou '+it.type);beep(650);}else{log('Inventário cheio');}items.splice(ii,1);}
    if(map[ny][nx]===2){if(level<3){level++;log('Desceu L'+level);genLevel(level);beep(1200);}else{endGame(true);return;}}
    
    monsters.forEach(m=>{if(Math.abs(m.x-player.x)+Math.abs(m.y-player.y)>6&&Math.random()<0.7)return;const dx=Math.sign(player.x-m.x),dy=Math.sign(player.y-m.y);const nx=m.x+(Math.random()<0.6?dx:0),ny=m.y+(Math.random()<0.6?dy:0);if(nx>=0&&ny>=0&&nx<cols&&ny<rows&&map[ny][nx]!==1&&!monsters.some(o=>o!==m&&o.x===nx&&o.y===ny)&&!(nx===player.x&&ny===player.y)){m.x=nx;m.y=ny;}if(Math.abs(m.x-player.x)+Math.abs(m.y-player.y)===1&&Math.random()<0.4){player.hp-=m.atk;log(m.name+' ataca');beep(220);if(player.hp<=0){endGame(false);return;}}});
    
    updateVision();draw();saveGame();beep(450);
  }
  
  function saveGame(){localStorage.setItem('dungeon_save',JSON.stringify({level,player,gold,map,monsters,items,explored}));}
  
  function endGame(win){
    gameOver = true;
    localStorage.removeItem('dungeon_save');
    const best = Math.max(parseInt(localStorage.getItem('dungeon_best') || '0'), gold);
    localStorage.setItem('dungeon_best', best);
    
    const mg = document.getElementById('miniGame');
    // Botão SAIR com onclick inline direto – sem dependência de listeners assíncronos
    mg.innerHTML = `
      <div style="width:100%;height:100%;background:#000;color:#8fa133;display:flex;flex-direction:column;justify-content:center;align-items:center;font-family:'Press Start 2P';text-align:center;padding:10px;box-sizing:border-box">
        <div style="font-size:12px;margin-bottom:10px">${win ? 'VENCEU!' : 'MORREU'}</div>
        <div style="font-size:7px;margin-bottom:15px">Ouro: ${gold}  |  Recorde: ${best}</div>
        <button id="btnSair" onclick="closeMiniGame()" style="background:#8fa133;color:#000;border:3px solid #5a6d1f;padding:12px 20px;font-size:10px;font-family:'Press Start 2P';cursor:pointer;pointer-events:auto;z-index:1000">SAIR</button>
      </div>`;
    
    // Atualiza atributos do pet
    state.diversao = Math.min(100, state.diversao + (win ? 25 : 10) + Math.floor(gold / 4));
    state.qi = Math.min(100, state.qi + (win ? 10 : 4) + player.xp * 2);
    const bank = parseInt(localStorage.getItem('dungeon_gold_bank') || '0') + gold;
    localStorage.setItem('dungeon_gold_bank', bank);
    state.dinheiro += (win ? 20 : 5);
    state.estresse = Math.max(0, state.estresse - (win ? 15 : 0));
    if (!win) {
      state.doente = true;
      state.estresse = Math.min(100, state.estresse + 20);
    }
    save();
  }
  
  // inicializa
  if(save && save.map){map=save.map;monsters=save.monsters;items=save.items;explored=save.explored||explored;gold=save.gold;updateVision();}else{genLevel(level);}
  draw();log('L'+level+' - ache o ☥');
  
  document.getElementById('nhUp').onclick=()=>move(0,-1);
  document.getElementById('nhDown').onclick=()=>move(0,1);
  document.getElementById('nhLeft').onclick=()=>move(-1,0);
  document.getElementById('nhRight').onclick=()=>move(1,0);
  document.getElementById('nhShop').onclick=()=>{
    saveGame();
    const shopDiv=document.createElement('div');
    shopDiv.style.cssText='position:absolute;inset:0;background:#8fa133;z-index:50;padding:6px;display:flex;flex-direction:column';
    shopDiv.innerHTML=`<div style="color:#1a2a0f;font-size:8px;text-align:center">🛒 LOJA</div><div style="background:#c8d6a8;border:2px solid #000;padding:3px;margin:4px 0;font-size:7px">OURO BANCO: ${localStorage.getItem('dungeon_gold_bank')||0}$</div><div id="shopBtns" style="display:flex;flex-direction:column;gap:3px;overflow:auto"></div><button id="closeShop" style="margin-top:auto;background:#1a2a0f;color:#8fa133;border:1px solid #000;font-size:7px;padding:4px">FECHAR</button>`;
    mg.appendChild(shopDiv);
    const items=[{id:'vit',n:'💊 Vitamina',c:30,f:()=>{let g=parseInt(localStorage.getItem('dungeon_gold_bank')||0);if(g>=30){g-=30;localStorage.setItem('dungeon_gold_bank',g);state.doente=false;state.higiene=100;msg('Comprou!');save();}}},{id:'food',n:'🍖 Ração',c:20,f:()=>{let g=parseInt(localStorage.getItem('dungeon_gold_bank')||0);if(g>=20){g-=20;localStorage.setItem('dungeon_gold_bank',g);state.fome=Math.min(100,state.fome+30);msg('+30 fome');save();}}},{id:'rev',n:'💖 Reviver',c:100,f:()=>{let g=parseInt(localStorage.getItem('dungeon_gold_bank')||0);if(g>=100&&!state.vivo){g-=100;localStorage.setItem('dungeon_gold_bank',g);state.vivo=true;state.fome=70;state.sono=70;msg('Reviveu!');save();}}}];
    const btns=shopDiv.querySelector('#shopBtns');
    items.forEach(it=>{const b=document.createElement('button');b.style.cssText='background:#1a2a0f;color:#8fa133;border:1px solid #000;font-size:7px;padding:4px;text-align:left';b.innerHTML=`${it.n} - ${it.c}$`;b.onclick=()=>{it.f();shopDiv.querySelector('div:nth-child(2)').innerHTML=`OURO BANCO: ${localStorage.getItem('dungeon_gold_bank')||0}$`;};btns.appendChild(b);});
    shopDiv.querySelector('#closeShop').onclick=()=>shopDiv.remove();
  };
  document.onkeydown=(e)=>{if(!mg.classList.contains('active'))return;if(e.key==='ArrowUp')move(0,-1);if(e.key==='ArrowDown')move(0,1);if(e.key==='ArrowLeft')move(-1,0);if(e.key==='ArrowRight')move(1,0);if(e.key>='1'&&e.key<='6')useItem(parseInt(e.key)-1);if(e.key==='s'||e.key==='S')document.getElementById('nhShop').click();};
}

setInterval(()=>{
  if (!state.vivo) return;
  const diff = (Date.now() - state.lastUpdate)/1000; state.lastUpdate = Date.now();
  if (state.dormindo) {
    state.sono = Math.min(100, state.sono + diff*1.8);
    state.fome = Math.max(0, state.fome - diff*0.25);
    state.estresse = Math.max(0, state.estresse - diff*1.2);
    if (state.sono > 98) { state.dormindo=false; document.getElementById('sleepOverlay').classList.remove('active'); }
  } else {
    state.fome = Math.max(0, state.fome - diff*0.45);
    state.sono = Math.max(0, state.sono - diff*0.38);
    state.higiene = Math.max(0, state.higiene - diff*0.18);
    state.diversao = Math.max(0, state.diversao - diff*0.32);
    if (state.diversao < 30) state.estresse = Math.min(100, state.estresse + diff*0.4);
    if (state.higiene < 20) state.estresse = Math.min(100, state.estresse + diff*0.3);
    if (state.sono < 28 && state.sono > 27 && !state.dormindo && Math.random()<0.1) { msg('SONO...'); }
  }
  if (state.higiene < 25 && !state.sujo && Math.random()<0.008) { state.sujo=true; document.getElementById('poop').style.display='block'; state.disciplina = Math.max(0, state.disciplina - 3); }
  if (!state.doente && state.higiene < 20 && state.estresse > 60 && Math.random()<0.005) { state.doente = true; msg('DOENTE!'); }
  if (state.doente) { state.estresse = Math.min(100, state.estresse + diff*0.5); state.diversao = Math.max(0, state.diversao - diff*0.2); }
  if (state.fome<=0 && state.sono<=0) { state.vivo=false; msg('...'); }
  if (state.estresse >= 100) { state.vivo=false; msg('STRESS!'); }
  if (!localStorage.getItem('tama_eat_v1_start')) localStorage.setItem('tama_eat_v1_start', Date.now());
  const novaIdade = Math.floor((Date.now() - parseInt(localStorage.getItem('tama_eat_v1_start')))/86400000)+1;
  if (novaIdade !== state.idade) {
    state.idade = novaIdade;
    if (state.idade === 2 || state.idade === 3) {
      if (state.estresse < 30 && state.disciplina > 70 && state.qi > 20) {
        msg('EVOLUIU BEM!');
        state.estresse = Math.max(0, state.estresse - 10);
      } else {
        msg('EVOLUIU MAL');
        state.estresse = Math.min(100, state.estresse + 10);
      }
    }
  } else {
    state.idade = novaIdade;
  }
  updateBars(); save();
}, 1000);

updateBars();
document.getElementById('sleepOverlay').classList.toggle('active', state.dormindo);
document.getElementById('poop').style.display = state.sujo ? 'block' : 'none';

function showStatus(){
  const s = document.getElementById('statusScreen');
  s.classList.add('active');
  let type = 'Bebê';
  if(state.idade >= 3 && state.qi > 40) type = 'Intelig';
  else if(state.idade >= 3) type = 'Adolesc';
  else if(state.idade >= 2) type = 'Criança';
  document.getElementById('stType').textContent = type;
  document.getElementById('stAge').textContent = state.idade + ' anos';
  const weight = 30 + Math.floor(state.fome/4) + Math.floor(state.qi/10) + Math.floor(state.pesoExtra);
  document.getElementById('stWeight').textContent = weight + 'g';
  document.getElementById('stMoney').textContent = state.dinheiro;
  
  function hearts(el, val){
    const h = Math.ceil(val/25);
    el.innerHTML = '';
    for(let i=0;i<4;i++){
      const span = document.createElement('span');
      span.className='heart';
      span.textContent = i < h ? '♥' : '♡';
      el.appendChild(span);
    }
  }
  const lifeVal = Math.floor((state.fome + state.sono + state.higiene)/3);
  hearts(document.getElementById('stLife'), lifeVal);
  hearts(document.getElementById('stFun'), state.diversao);
  
  document.getElementById('stIQ').style.width = state.qi + '%';
  document.getElementById('stBody').style.width = state.disciplina + '%';
  document.getElementById('stDeed').style.width = (100 - state.estresse) + '%';
  
  document.getElementById('stStress').textContent = Math.floor(state.estresse);
  document.getElementById('stDisc').textContent = Math.floor(state.disciplina);
}
document.getElementById('statusClose').onclick = ()=> document.getElementById('statusScreen').classList.remove('active');
document.getElementById('age').style.cursor='pointer';
document.getElementById('age').onclick = showStatus;

</script>

<script>
document.addEventListener('DOMContentLoaded', function(){
  const startScreen = document.getElementById('startScreen');
  const selectScreen = document.getElementById('selectScreen');
  const startBtn = document.getElementById('startBtn');
  const nameInput = document.getElementById('petNameInput');
  const nameDisplay = document.getElementById('petNameDisplay');
  const petListEl = document.getElementById('petList');
  const newPetBtn = document.getElementById('newPetBtn');

  if(nameInput && nameDisplay){
    nameInput.addEventListener('input', ()=>{
      const preview = (nameInput.value.trim().toUpperCase() || 'PET').substring(0,8);
      nameDisplay.textContent = preview;
    });
  }

  function getPets(){
    let pets = JSON.parse(localStorage.getItem('tamagotchi_pets_v2') || '[]');
    if(pets.length===0 && localStorage.getItem('tama_eat_v1')){
      try{
        const old = JSON.parse(localStorage.getItem('tama_eat_v1'));
        const oldName = localStorage.getItem('tamagotchi_pet_name') || 'PET';
        pets.push({id: Date.now(), nome: oldName, state: old, created: Date.now()});
        localStorage.setItem('tamagotchi_pets_v2', JSON.stringify(pets));
      }catch(e){}
    }
    return pets;
  }
  function savePets(pets){ localStorage.setItem('tamagotchi_pets_v2', JSON.stringify(pets)); }
  function getCurrentId(){ return localStorage.getItem('tamagotchi_current_id'); }
  function setCurrentId(id){ localStorage.setItem('tamagotchi_current_id', id); }

  const originalSave = window.save;
  window.save = function(){
    if(typeof originalSave === 'function') originalSave();
    const pets = getPets();
    const id = getCurrentId();
    const idx = pets.findIndex(p=> String(p.id)===String(id));
    if(idx>=0){
      pets[idx].state = window.state;
      pets[idx].nome = window.state.nome || pets[idx].nome;
      savePets(pets);
    }
  };

  function loadPetIntoGame(pet){
    setCurrentId(pet.id);
    window.state = pet.state;
    window.state.nome = pet.nome;
    localStorage.setItem('tama_eat_v1', JSON.stringify(pet.state));
    if(nameDisplay) nameDisplay.textContent = pet.nome || pet.state?.nome || 'PET';
    selectScreen.style.display='none';
    startScreen.style.display='none';
    const msgEl = document.getElementById('msg');
    if(msgEl){ msgEl.textContent = 'OI, ' + pet.nome + '!'; msgEl.style.display='block'; setTimeout(()=>msgEl.style.display='none',1200); }
    if(typeof updateBars === 'function') updateBars();
  }

  function renderPetList(){
    const pets = getPets();
    petListEl.innerHTML = '';
    if(pets.length===0){
      petListEl.innerHTML = '<div style="font-size:8px;color:#5a6d1f;text-align:center;padding:10px">NENHUM PET AINDA</div>';
      return;
    }
    pets.sort((a,b)=> b.created - a.created).forEach(pet=>{
      const age = pet.state?.idade || 1;
      const fome = Math.floor(pet.state?.fome || 0);
      const card = document.createElement('div');
      card.className = 'petCard';
      card.innerHTML = `<div class="petInfo">${pet.nome}<span>DIA ${age} • FOME ${fome}%</span></div><div class="petPlay">CUIDAR</div>`;
      card.onclick = ()=> loadPetIntoGame(pet);
      petListEl.appendChild(card);
    });
  }

  function showSelect(){
    startScreen.style.display='none';
    selectScreen.style.display='flex';
    renderPetList();
  }

  function createNewPet(name){
    const id = Date.now();
    const newState = {
      fome:85, sono:85, higiene:85, diversao:70, estresse:15, disciplina:50, qi:5,
      dinheiro:20, idade:1, vivo:true, dormindo:false, sujo:false, doente:false,
      pesoExtra:0, lastUpdate:Date.now(), nome:name
    };
    const pets = getPets();
    pets.push({id, nome:name, state:newState, created:Date.now()});
    savePets(pets);
    loadPetIntoGame({id, nome:name, state:newState});
  }

  const seen = localStorage.getItem('tamagotchi_seen_welcome');
  if(!seen){
    startScreen.style.display='flex';
    selectScreen.style.display='none';
  }else{
    startScreen.style.display='none';
    showSelect();
  }

  if(startBtn){
    startBtn.addEventListener('click', function(){
      const name = (nameInput.value.trim().toUpperCase() || 'PET').substring(0,8);
      localStorage.setItem('tamagotchi_seen_welcome','1');
      localStorage.setItem('tamagotchi_pet_name', name);
      window.pendingPetName = name;
      startScreen.style.display='none';
      document.getElementById('choiceScreen').style.display='flex';
    });
 
  document.getElementById('goCustomize').onclick = () => {
    document.getElementById('choiceScreen').style.display='none';
    document.getElementById('customizeScreen').style.display='flex';
  };
  document.getElementById('useDefault').onclick = () => {
    document.getElementById('choiceScreen').style.display='none';
    localStorage.removeItem('tamagotchi_custom_v1');
    localStorage.removeItem('tamagotchi_sounds_v1');
    localStorage.removeItem('tamagotchi_bg_v1');
    createNewPet(window.pendingPetName || 'PET');
  };
 }

  if(newPetBtn){
    newPetBtn.addEventListener('click', ()=>{
      const name = prompt('NOME DO NOVO PET (max 8):', 'PET') || 'PET';
      const clean = name.trim().toUpperCase().substring(0,8) || 'PET';
      window.pendingPetName = clean;
      selectScreen.style.display='none';
      document.getElementById('customizeScreen').style.display='flex';
    });
  }
  // --- Personalização ---
  const custSave = document.getElementById('custSave');
  const custSkip = document.getElementById('custSkip');
  const custSize = document.getElementById('custSize');
  const sizeVal = document.getElementById('sizeVal');
  if(custSize){ custSize.oninput = ()=> sizeVal.textContent = custSize.value + '%'; }

  const pixelEditor = document.getElementById('pixelEditor');
  const drawCanvas = document.getElementById('drawCanvas');
  const dCtx = drawCanvas.getContext('2d');
  const paletteEl = document.getElementById('palette');
  const editName = document.getElementById('editSpriteName');
  let GRID = 32, SCALE = 10;
  let currentSprite = null, currentTool = 'brush', currentColor = '#1a2a0f';
  let isDrawing = false;
  const drawnSprites = {};

  const colors = ['#000000','#1a2a0f','#5a6d1f','#8fa133','#c8d6a8','#ffffff','#ff0000','#ff8000','#ffff00','#00ff00','#00ffff','#0000ff','#8000ff','#ff00ff','#964B00','#808080'];
  colors.forEach(c=>{
    const d=document.createElement('div'); d.className='col'; d.style.background=c; d.onclick=()=>{currentColor=c; document.querySelectorAll('.col').forEach(x=>x.classList.remove('active')); d.classList.add('active');}; paletteEl.appendChild(d);
  });
  paletteEl.firstChild.classList.add('active');

  function initDrawCanvas(size=32){
    GRID=size; SCALE = 320/GRID;
    dCtx.clearRect(0,0,320,320);
    dCtx.fillStyle='#fff'; dCtx.fillRect(0,0,320,320);
    dCtx.strokeStyle='rgba(0,0,0,0.1)'; for(let i=0;i<=GRID;i++){ dCtx.beginPath(); dCtx.moveTo(i*SCALE,0); dCtx.lineTo(i*SCALE,320); dCtx.stroke(); dCtx.beginPath(); dCtx.moveTo(0,i*SCALE); dCtx.lineTo(320,i*SCALE); dCtx.stroke(); }
  }
  initDrawCanvas(currentSprite==='background'?64:32);

  function getPixel(e){
    const rect=drawCanvas.getBoundingClientRect(); const x=Math.floor(((e.touches?e.touches[0].clientX:e.clientX)-rect.left)/rect.width*GRID); const y=Math.floor(((e.touches?e.touches[0].clientY:e.clientY)-rect.top)/rect.height*GRID); return {x:Math.max(0,Math.min(GRID-1,x)), y:Math.max(0,Math.min(GRID-1,y))};
  }
  function drawPixel(x,y,color){ dCtx.fillStyle=color; dCtx.fillRect(x*SCALE+1,y*SCALE+1,SCALE-2,SCALE-2); }

  drawCanvas.addEventListener('mousedown',e=>{isDrawing=true; const p=getPixel(e); if(currentTool==='brush')drawPixel(p.x,p.y,currentColor); else if(currentTool==='eraser')drawPixel(p.x,p.y,'#fff');});
  drawCanvas.addEventListener('mousemove',e=>{if(!isDrawing)return; const p=getPixel(e); if(currentTool==='brush')drawPixel(p.x,p.y,currentColor); else if(currentTool==='eraser')drawPixel(p.x,p.y,'#fff');});
  window.addEventListener('mouseup',()=>isDrawing=false);
  drawCanvas.addEventListener('touchstart',e=>{e.preventDefault(); isDrawing=true; const p=getPixel(e); drawPixel(p.x,p.y,currentTool==='eraser'?'#fff':currentColor);});
  drawCanvas.addEventListener('touchmove',e=>{e.preventDefault(); if(!isDrawing)return; const p=getPixel(e); drawPixel(p.x,p.y,currentTool==='eraser'?'#fff':currentColor);});
  window.addEventListener('touchend',()=>isDrawing=false);

  document.getElementById('toolBrush').onclick=()=>currentTool='brush';
  document.getElementById('toolEraser').onclick=()=>currentTool='eraser';
  document.getElementById('toolClear').onclick=initDrawCanvas;
  let zoomLevel=1; let gridOn=true;
  function redrawGrid(){
    const imgData = dCtx.getImageData(0,0,320,320);
    dCtx.clearRect(0,0,320,320);
    dCtx.putImageData(imgData,0,0);
    if(!gridOn) return;
    dCtx.strokeStyle='rgba(0,0,0,'+Math.min(0.4,0.08*zoomLevel)+')';
    dCtx.lineWidth = zoomLevel>1.5?1.5:1;
    for(let i=0;i<=GRID;i++){ dCtx.beginPath(); dCtx.moveTo(i*SCALE,0); dCtx.lineTo(i*SCALE,320); dCtx.stroke(); dCtx.beginPath(); dCtx.moveTo(0,i*SCALE); dCtx.lineTo(320,i*SCALE); dCtx.stroke(); }
  }
  document.getElementById('toolZoomIn').onclick=()=>{ zoomLevel=Math.min(3,zoomLevel+0.5); drawCanvas.style.width=(zoomLevel*100)+'%'; redrawGrid(); };
  document.getElementById('toolZoomOut').onclick=()=>{ zoomLevel=Math.max(0.5,zoomLevel-0.5); drawCanvas.style.width=(zoomLevel*100)+'%'; redrawGrid(); };
  document.getElementById('toolGrid').onclick=()=>{
    gridOn=!gridOn; document.getElementById('toolGrid').textContent = gridOn ? 'GRADE ON' : 'GRADE OFF';
    const temp = document.createElement('canvas'); temp.width=320; temp.height=320;
    const tCtx = temp.getContext('2d'); tCtx.drawImage(drawCanvas,0,0);
    const size = GRID;
    const small = document.createElement('canvas'); small.width=size; small.height=size;
    const sCtx = small.getContext('2d'); sCtx.imageSmoothingEnabled=false;
    sCtx.drawImage(temp,0,0,320,320,0,0,size,size);
    dCtx.clearRect(0,0,320,320);
    dCtx.imageSmoothingEnabled=false;
    dCtx.drawImage(small,0,0,size,size,0,0,320,320);
    if(gridOn) redrawGrid();
  };
  document.getElementById('toolFill').onclick=()=>{ dCtx.fillStyle=currentColor; dCtx.fillRect(0,0,320,320); initDrawCanvas(currentSprite==='background'?64:32); dCtx.fillStyle=currentColor; dCtx.fillRect(1,1,318,318); };

  document.querySelectorAll('.drawBtn').forEach(btn=>{
    btn.onclick=()=>{
      currentSprite=btn.dataset.sprite;
      editName.textContent=currentSprite.toUpperCase();
      pixelEditor.style.display='flex';
      initDrawCanvas(currentSprite==='background'?64:32);
      const prev = drawnSprites[currentSprite] || JSON.parse(localStorage.getItem('tamagotchi_custom_v1')||'{}')['spr'+currentSprite.charAt(0).toUpperCase()+currentSprite.slice(1)];
      if(prev){ const img=new Image(); img.onload=()=>{ dCtx.drawImage(img,0,0,32,32,0,0,320,320); }; img.src=prev; }
    };
  });
  document.getElementById('drawBgBtn').onclick=()=>{ currentSprite='background'; editName.textContent='FUNDO'; pixelEditor.style.display='flex'; initDrawCanvas(64); const prev=localStorage.getItem('tamagotchi_bg_v1'); if(prev){ const img=new Image(); img.onload=()=>{ dCtx.drawImage(img,0,0,64,64,0,0,320,320); }; img.src=prev; } };

  document.getElementById('cancelSprite').onclick=()=>{ pixelEditor.style.display='none'; };
  document.getElementById('saveSprite').onclick=()=>{
    const size = currentSprite==='background'?64:32;
    const tmp=document.createElement('canvas'); tmp.width=size; tmp.height=size; const tCtx=tmp.getContext('2d'); tCtx.imageSmoothingEnabled=false;
    
    if(currentSprite==='background'){
      tCtx.fillStyle = '#ffffff';
      tCtx.fillRect(0,0,size,size);
      tCtx.drawImage(drawCanvas,0,0,320,320,0,0,size,size);
    } else {
      tCtx.drawImage(drawCanvas,0,0,320,320,0,0,size,size);
    }
    
    const dataURL=tmp.toDataURL();
    drawnSprites[currentSprite]=dataURL;
    if(currentSprite==='background'){
      localStorage.setItem('tamagotchi_bg_v1', dataURL);
      document.getElementById('bgPreview').getContext('2d').drawImage(tmp,0,0,64,48);
      const mode = document.getElementById('bgMode')?.value || 'stretch';
      localStorage.setItem('tamagotchi_bg_mode', mode);
      window.bgImage = new Image(); window.bgImage.src = dataURL;
      const lcd = document.querySelector('.lcd');
      if(lcd){
        lcd.style.setProperty('background-image', `url(${dataURL})`, 'important');
        lcd.style.setProperty('background-size', mode==='repeat' ? '64px 64px' : '100% 100%', 'important');
        lcd.style.setProperty('background-repeat', mode==='repeat' ? 'repeat' : 'no-repeat', 'important');
        lcd.style.setProperty('background-position', 'center', 'important');
        lcd.style.imageRendering = 'pixelated';
      }
    } else { document.getElementById('prev'+currentSprite.charAt(0).toUpperCase()+currentSprite.slice(1)).getContext('2d').drawImage(tmp,0,0); }
    pixelEditor.style.display='none';
  };
  document.getElementById('uploadSprite').onclick=()=>{
    document.getElementById('uploadSpriteInput').click();
  };
  document.getElementById('uploadSpriteInput').onchange=(e)=>{
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = (ev)=>{
      const img = new Image();
      img.onload = ()=>{
        dCtx.clearRect(0,0,320,320);
        dCtx.imageSmoothingEnabled = false;
        const size = 320;
        dCtx.drawImage(img, 0, 0, size, size);
      };
      img.src = ev.target.result;
    };
    reader.readAsDataURL(file);
    e.target.value = '';
  };

  // --- Editor de Som Chiptune ---
  const soundEditor = document.getElementById('soundEditor');
  const sequencer = document.getElementById('sequencer');
  const soundNotes = document.getElementById('soundNotes');
  let currentSound = null;
  let seq = Array(8).fill(null);
  const notes = [{n:'C4',f:261.6},{n:'D4',f:293.7},{n:'E4',f:329.6},{n:'F4',f:349.2},{n:'G4',f:392},{n:'A4',f:440},{n:'B4',f:493.9}];
  notes.forEach(note=>{ const b=document.createElement('button'); b.className='noteBtn'; b.textContent=note.n; b.onclick=()=>{ if(window.selStep!=null){ seq[window.selStep]=note.f; updateSeq(); } }; soundNotes.appendChild(b); });
  function buildSeq(){ sequencer.innerHTML=''; for(let i=0;i<8;i++){ const d=document.createElement('div'); d.className='seqStep'; d.textContent=i+1; d.onclick=()=>{ window.selStep=i; document.querySelectorAll('.seqStep').forEach(s=>s.classList.remove('active')); d.classList.add('active'); }; sequencer.appendChild(d); } }
  buildSeq();
  function updateSeq(){ document.querySelectorAll('.seqStep').forEach((d,i)=>{ d.textContent = seq[i] ? notes.find(n=>n.f===seq[i]).n : i+1; }); }
  document.getElementById('clearSound').onclick=()=>{ seq=Array(8).fill(null); updateSeq(); };
  document.getElementById('playSound').onclick=()=>{ const ctx=new (window.AudioContext||window.webkitAudioContext)(); let t=ctx.currentTime; seq.forEach(f=>{ if(f){ const o=ctx.createOscillator(); const g=ctx.createGain(); o.type='square'; o.frequency.value=f; o.connect(g); g.connect(ctx.destination); g.gain.setValueAtTime(0.2,t); g.gain.exponentialRampToValueAtTime(0.01,t+0.15); o.start(t); o.stop(t+0.15); t+=0.18; } else { t+=0.18; } }); };
  document.querySelectorAll('.soundBtn').forEach(btn=>{ btn.onclick=()=>{ currentSound=btn.dataset.sound; document.getElementById('editSoundName').textContent=currentSound.toUpperCase(); soundEditor.style.display='flex'; const saved=JSON.parse(localStorage.getItem('tamagotchi_sounds_v1')||'{}'); seq=saved[currentSound]||Array(8).fill(null); updateSeq(); }; });
  document.getElementById('cancelSound').onclick=()=>{ soundEditor.style.display='none'; };
  document.getElementById('saveSound').onclick=()=>{ const saved=JSON.parse(localStorage.getItem('tamagotchi_sounds_v1')||'{}'); saved[currentSound]=seq; localStorage.setItem('tamagotchi_sounds_v1',JSON.stringify(saved)); soundEditor.style.display='none'; };

  window.playActionSound = function(action){
    try{
      const sounds = JSON.parse(localStorage.getItem('tamagotchi_sounds_v1')||'{}');
      const s = sounds[action]; if(!s) return;
      const ctx = new (window.AudioContext||window.webkitAudioContext)();
      let t = ctx.currentTime;
      s.forEach(f=>{ if(f){ const o=ctx.createOscillator(); const g=ctx.createGain(); o.type='square'; o.frequency.value=f; o.connect(g); g.connect(ctx.destination); g.gain.setValueAtTime(0.15,t); g.gain.exponentialRampToValueAtTime(0.01,t+0.12); o.start(t); o.stop(t+0.12); t+=0.14; } else { t+=0.14; } });
    }catch(e){}
  };

  ['Normal','Sleep','Eat','Bath','Med','Play','Sick','Sad','Hungry','Angry','Happy'].forEach(n=>{ const c=document.getElementById('prev'+n); const ctx=c.getContext('2d'); ctx.fillStyle='#fff'; ctx.fillRect(0,0,32,32); });
  const savedPrev = JSON.parse(localStorage.getItem('tamagotchi_custom_v1')||'{}');
  ['normal','sleep','eat','bath','med','play','sick','sad','hungry','angry','happy'].forEach(k=>{ const key='spr'+k.charAt(0).toUpperCase()+k.slice(1); if(savedPrev[key]){ const img=new Image(); img.onload=()=>{ document.getElementById('prev'+k.charAt(0).toUpperCase()+k.slice(1)).getContext('2d').drawImage(img,0,0,32,32); }; img.src=savedPrev[key]; } });

  async function saveCustomAndStart(){
    const custom = JSON.parse(localStorage.getItem('tamagotchi_custom_v1')||'{}');
    custom.deviceColor = document.getElementById('custDevice').value;
    custom.lcdColor = document.getElementById('custLcd').value;
    custom.petSize = parseInt(document.getElementById('custSize').value);
    custom.sprNormal = drawnSprites.normal || custom.sprNormal;
    custom.sprSleep = drawnSprites.sleep || custom.sprSleep;
    custom.sprEat = drawnSprites.eat || custom.sprEat;
    custom.sprBath = drawnSprites.bath || custom.sprBath;
    custom.sprMed = drawnSprites.med || custom.sprMed;
    custom.sprPlay = drawnSprites.play || custom.sprPlay;
    custom.sprSick = drawnSprites.sick || custom.sprSick;
    custom.sprSad = drawnSprites.sad || custom.sprSad;
    custom.sprHungry = drawnSprites.hungry || custom.sprHungry;
    custom.sprAngry = drawnSprites.angry || custom.sprAngry;
    custom.sprHappy = drawnSprites.happy || custom.sprHappy;
    localStorage.setItem('tamagotchi_custom_v1', JSON.stringify(custom));
    applyCustomization(custom);
    document.getElementById('customizeScreen').style.display='none';
    createNewPet(window.pendingPetName || 'PET');
  }

  if(custSave){ custSave.onclick = saveCustomAndStart; }
  if(custSkip){ custSkip.onclick = ()=>{ document.getElementById('customizeScreen').style.display='none'; createNewPet(window.pendingPetName || 'PET'); }; }

  function applyCustomization(custom){
    if(!custom) return;
    if(custom.deviceColor){ document.querySelector('.device').style.background = custom.deviceColor; }
    if(custom.lcdColor){
      document.querySelectorAll('.lcd, #customizeScreen, #selectScreen, #startScreen').forEach(el=> el.style.backgroundColor = custom.lcdColor);
      document.querySelectorAll('.game-menu, .mini-game').forEach(el=> el.style.backgroundColor = custom.lcdColor);
    }
    window.customPetSize = custom.petSize || 65;
    if(custom.sprNormal){ normal1.src = normal2.src = custom.sprNormal; }
    if(custom.sprSleep){ sleepy1.src = sleepy2.src = custom.sprSleep; }
    if(custom.sprEat){ eat1.src = eat2.src = eat3.src = custom.sprEat; }
  }

  const savedCustom = JSON.parse(localStorage.getItem('tamagotchi_custom_v1')||'null');
  if(savedCustom){ applyCustomization(savedCustom); }

  // Carrega sala atual
  if(state.currentRoom && state.rooms && state.rooms[state.currentRoom]){
    setTimeout(()=> applyRoomVisual(state.currentRoom), 100);
  }

  const savedBg = localStorage.getItem('tamagotchi_bg_v1');
  const savedMode = localStorage.getItem('tamagotchi_bg_mode') || 'stretch';
  if(document.getElementById('bgMode')) document.getElementById('bgMode').value = savedMode;
  if(savedBg){
    window.bgImage = new Image(); window.bgImage.src = savedBg;
    const lcd = document.querySelector('.lcd');
    if(lcd){
      lcd.style.setProperty('background-image', `url(${savedBg})`, 'important');
      lcd.style.setProperty('background-size', savedMode==='repeat' ? '64px 64px' : '100% 100%', 'important');
      lcd.style.setProperty('background-repeat', savedMode==='repeat' ? 'repeat' : 'no-repeat', 'important');
      lcd.style.setProperty('background-position', 'center', 'important');
      lcd.style.imageRendering = 'pixelated';
    }
    const petCanvas = document.getElementById('pet');
    if(petCanvas){ petCanvas.style.width='65%'; petCanvas.style.height='65%'; petCanvas.style.position=''; petCanvas.style.top=''; petCanvas.style.left=''; petCanvas.style.zIndex=''; }
    document.getElementById('petArea').style.inset = '28px 0 6px 0';
  }

  const currentId = getCurrentId();
  if(currentId && seen){
    const pets = getPets();
    const pet = pets.find(p=> String(p.id)===String(currentId));
    if(pet){
      selectScreen.style.display='none';
      startScreen.style.display='none';
      window.state = pet.state;
      window.state.nome = pet.nome;
      if(nameDisplay) nameDisplay.textContent = pet.nome || pet.state?.nome || 'PET';
    }
  }

  const toggleFS = document.getElementById('toggleFS');
  if(toggleFS){
    toggleFS.onclick = ()=>{
      document.querySelector('.device').classList.toggle('fullscreen');
      toggleFS.textContent = document.querySelector('.device').classList.contains('fullscreen') ? 'JANELA' : 'TELA CHEIA';
      localStorage.setItem('tamagotchi_fs', document.querySelector('.device').classList.contains('fullscreen') ? '1' : '0');
    };
    if(localStorage.getItem('tamagotchi_fs')=='1'){
      document.querySelector('.device').classList.add('fullscreen');
      toggleFS.textContent = 'JANELA';
    }
  }

});
</script>
</body>
</html>