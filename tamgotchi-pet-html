function applyRoomVisual(roomKey){
  // esconde todos
  document.querySelectorAll('.room-visual').forEach(el=> el.style.display='none');
  const lcd = document.querySelector('.lcd');
  
  // reseta fundo
  if(lcd){
    lcd.style.backgroundColor = '#8fa133';
    lcd.style.backgroundImage = 'linear-gradient(rgba(0,0,0,0.07) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.07) 1px, transparent 1px)';
    lcd.style.backgroundSize = '3px 3px';
  }
  
  state.currentRoom = roomKey;
  localStorage.setItem('tamagotchi_current_room', roomKey);
  
  // === NOVO: esconde o tamagotchi no Bestiário para melhor visualização ===
  const petCanvas = document.getElementById('pet');
  const poopEl = document.getElementById('poop');
  if(petCanvas) petCanvas.style.display = (roomKey === 'bestiary') ? 'none' : 'block';
  if(poopEl) poopEl.style.display = (roomKey === 'bestiary') ? 'none' : 'block';
  
  if(roomKey === 'kitchen'){
    // usa a imagem pixel art que você enviou
    if(lcd){
      lcd.style.backgroundImage = `url(${KITCHEN_BG})`;
      lcd.style.backgroundSize = '100% 100%';
      lcd.style.backgroundRepeat = 'no-repeat';
      lcd.style.backgroundPosition = 'center';
    }
  } else if(roomKey === 'shop'){
    document.getElementById('roomShopVisual').style.display = 'block';
    if(lcd){
      lcd.style.backgroundImage = `url(${SHOP_BG})`;
      lcd.style.backgroundSize = '100% 100%';
      lcd.style.backgroundRepeat = 'no-repeat';
      lcd.style.backgroundPosition = 'center';
    }
  } else if(roomKey === 'bestiary'){
    document.getElementById('roomBestiaryVisual').style.display = 'block';
    setTimeout(()=>{if(typeof updateBestiaryDisplay==='function')updateBestiaryDisplay();},50);
    if(lcd) {
