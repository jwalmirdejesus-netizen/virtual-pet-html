<script>
const canvas = document.getElementById('pet');
const ctx = canvas.getContext('2d');
ctx.imageSmoothingEnabled = false;

let state = JSON.parse(localStorage.getItem('tama_eat_v1')) || {
  fome: 85, sono: 85, higiene: 85, diversao: 85, idade: 1, vivo: true, dormindo: false, sujo: false, lastUpdate: Date.now(),
  estresse: 0, disciplina: 50, qi: 10, doente: false, gameMode: 0, pesoExtra: 0, dinheiro: 50
};
// Corrige valores NaN de saves antigos
state.fome = Number(state.fome); if (isNaN(state.fome)) state.fome = 85;
state.sono = Number(state.sono); if (isNaN(state.sono)) state.sono = 85;
state.higiene = Number(state.higiene); if (isNaN(state.higiene)) state.higiene = 85;
state.diversao = Number(state.diversao); if (isNaN(state.diversao)) state.diversao = 85;
state.estresse = Number(state.estresse); if (isNaN(state.estresse)) state.estresse = 0;
state.disciplina = Number(state.disciplina); if (isNaN(state.disciplina)) state.disciplina = 50;
state.qi = Number(state.qi); if (isNaN(state.qi)) state.qi = 10;
state.idade = Number(state.idade); if (isNaN(state.idade)) state.idade = 1;
state.pesoExtra = Number(state.pesoExtra); if (isNaN(state.pesoExtra)) state.pesoExtra = 0;
state.dinheiro = Number(state.dinheiro); if (isNaN(state.dinheiro)) state.dinheiro = 50;
state.rooms = state.rooms || JSON.parse(localStorage.getItem('tamagotchi_rooms_v1')||'{}');
state.currentRoom = localStorage.getItem('tamagotchi_current_room') || null;



const sprite = new Image();
sprite.src = 'data:image/png;base64,';

// Sprites normais - 2 frames (idle)
const normal1 = new Image();
normal1.src = 'data:image/png;base64,';
const normal2 = new Image();
normal2.src = 'data:image/png;base64,';
const normalSprites = [normal1, normal2];

// Sprites com sono
const sleepy1 = new Image();
sleepy1.src = 'data:image/png;base64,';
const sleepy2 = new Image();
sleepy2.src = 'data:image/png;base64,';
const sleepy3 = new Image();
  sleepy3.src = 'data:image/png;base64, ';
  const sleepySprites = [sleepy1, sleepy2];

// Sprites de comer - 3 frames
const eat1 = new Image();
eat1.src = 'data:image/png;base64,';
const eat2 = new Image();
eat2.src = 'data:image/png;base64,';
const eat3 = new Image();
eat3.src = 'data:image/png;base64,';
const eatSprites = [eat1, eat2, eat3];

// Sprites tristes - 3 frames (do usuário)
const sad1 = new Image();
sad1.src = 'data:image/png;base64,';
const sad2 = new Image();
sad2.src = 'data:image/png;base64,';
const sad3 = new Image();
sad3.src = 'data:image/png;base64,';

const sadSprites = [sad1, sad2, sad3];

// Sprites felizes - 2 frames (do usuário)
const happy1 = new Image();
happy1.src = 'data:image/png;base64,';
const happy2 = new Image();
happy2.src = 'data:image/png;base64,';

const happySprites = [happy1, happy2];

let frame = 0;
let eating = false;
let eatFrame = 0;
function draw() {
  ctx.clearRect(0,0,96,96);
  if (!normal1.complete || !normal2.complete || !eat1.complete || !eat2.complete || !eat3.complete || !sad1.complete || !sad2.complete || !sad3.complete || !happy1.complete || !happy2.complete) { requestAnimationFrame(draw); return; }
  
  const bob = Math.sin(frame * 0.07) * 1.2;
  const size = window.customPetSize || 64;
  const x = (96 - size)/2, y = (96 - size)/2 + bob;
  
  ctx.save();
  if (!state.vivo) ctx.globalAlpha = 0.35;
  if (state.dormindo) ctx.globalAlpha = 0.8;
  
  let currentSprite = normal1;
  
  if (state.vivo && !eating) {
    if (state.dormindo) {
      const idx = Math.floor(frame / 70) % normalSprites.length;
      currentSprite = normalSprites[idx];
    } else if (state.sono < 30) {
      const idx = Math.floor(frame / 50) % sleepySprites.length;
      currentSprite = sleepySprites[idx];
      if (!currentSprite.complete || currentSprite.naturalWidth === 0) {
        currentSprite = normalSprites[idx % normalSprites.length];
      }
    } else if (state.doente || state.fome < 20 || state.diversao < 15 || state.higiene < 15) {
      // usa os sprites tristes que você enviou
      const idx = Math.floor(frame / 40) % sadSprites.length;
      currentSprite = sadSprites[idx];
      if (!currentSprite.complete || currentSprite.naturalWidth === 0) {
        currentSprite = normalSprites[idx % normalSprites.length];
      }
    } else if (state.diversao > 85) {
      // usa os sprites felizes que você enviou
      const idx = Math.floor(frame / 35) % happySprites.length;
      currentSprite = happySprites[idx];
      if (!currentSprite.complete || currentSprite.naturalWidth === 0) {
        currentSprite = normalSprites[idx % normalSprites.length];
      }
    } else {
      const idx = Math.floor(frame / 50) % normalSprites.length;
      currentSprite = normalSprites[idx];
    }
  }
  
  if (eating && state.vivo && !state.dormindo) {
    const idx = Math.floor(eatFrame / 10) % eatSprites.length;
    currentSprite = eatSprites[idx];
    eatFrame++;
    if (eatFrame > 70) {
      eating = false;
      eatFrame = 0;
    }
  }
  
  ctx.drawImage(currentSprite, x, y, size, size);
  ctx.restore();
  
  if (frame % 200 < 2 && !state.dormindo && state.vivo && !eating) {
    ctx.clearRect(0,0,96,96);
  }
  
  frame++;
  requestAnimationFrame(draw);
}
draw();

function updateBars() {
  document.getElementById('fomeBar').style.width = state.fome + '%';
  document.getElementById('sonoBar').style.width = state.sono + '%';
  document.getElementById('higieneBar').style.width = state.higiene + '%';
  document.getElementById('diversaoBar').style.width = state.diversao + '%';
  document.getElementById('age').textContent = 'DIA ' + state.idade;
  const n = new Date(); document.getElementById('time').textContent = String(n.getHours()).padStart(2,'0')+':'+String(n.getMinutes()).padStart(2,'0');
}

function msg(t){ const m=document.getElementById('msg'); m.textContent=t; m.style.display='block'; setTimeout(()=>m.style.display='none',1100); }
function save(){ state.lastUpdate=Date.now(); localStorage.setItem('tama_eat_v1', JSON.stringify(state)); }
function effect(emoji){ const e=document.createElement('div'); e.className='effect'; e.textContent=emoji; e.style.left='50%'; e.style.top='40%'; document.getElementById('petArea').appendChild(e); setTimeout(()=>e.remove(),800); }

document.getElementById('btn1').onclick = () => {
  if (!state.vivo || state.dormindo) return;
  document.getElementById('foodMenu').classList.add('active');
};

function feed(tipo, fomeGain, emoji, msgText, stressDelta, discDelta) {
  window.playActionSound && window.playActionSound('eat');
  if (state.fome > 95) { msg('CHEIO!'); return; }
  state.fome = Math.min(100, state.fome + fomeGain);
  state.higiene = Math.max(0, state.higiene - 3);
  state.estresse = Math.max(0, Math.min(100, state.estresse + stressDelta));
  state.disciplina = Math.max(0, Math.min(100, state.disciplina + discDelta));
  eating = true; eatFrame = 0;
  effect(emoji); msg(msgText); save();
  document.getElementById('foodMenu').classList.remove('active');
}

document.getElementById('foodBack').onclick = () => {
  document.getElementById('foodMenu').classList.remove('active');
};
document.getElementById('foodPao').onclick = () => {
  if (state.dinheiro < 20) { msg('SEM DINHEIRO!'); return; }
  if (state.fome > 95) { msg('CHEIO!'); return; }
  state.dinheiro -= 20;
  feed('pao', 22, '🍞', 'PÃO!', -2, 2);
};
document.getElementById('foodDoce').onclick = () => {
  if (state.dinheiro < 40) { msg('SEM DINHEIRO!'); return; }
  if (state.fome > 95) { msg('CHEIO!'); return; }
  state.dinheiro -= 40;
  state.fome = Math.min(100, state.fome + 10);
  state.higiene = Math.max(0, state.higiene - 2);
  state.diversao = Math.min(100, state.diversao + 12);
  state.pesoExtra = Math.min(20, state.pesoExtra + 0.5);
  state.estresse = Math.min(100, state.estresse + 4);
  state.disciplina = Math.max(0, state.disciplina - 3);
  eating = true; eatFrame = 0;
  effect('🍬'); msg('DOCE! -15'); save();
  document.getElementById('foodMenu').classList.remove('active');
};
document.getElementById('foodBolo').onclick = () => {
  if (state.dinheiro < 40) { msg('SEM DINHEIRO!'); return; }
  if (state.fome > 95) { msg('CHEIO!'); return; }
  state.dinheiro -= 40;
  state.fome = Math.min(100, state.fome + 28);
  state.higiene = Math.max(0, state.higiene - 3);
  state.diversao = Math.min(100, state.diversao + 15);
  state.pesoExtra = Math.min(20, state.pesoExtra + 2);
  state.estresse = Math.max(0, state.estresse - 2);
  eating = true; eatFrame = 0;
  effect('🍰'); msg('BOLO! -40'); save();
  document.getElementById('foodMenu').classList.remove('active');
};
document.getElementById('foodPanqueca').onclick = () => {
  if (state.dinheiro < 30) { msg('SEM DINHEIRO!'); return; }
  if (state.fome > 95) { msg('CHEIO!'); return; }
  state.dinheiro -= 30;
  state.fome = Math.min(100, state.fome + 26);
  state.higiene = Math.max(0, state.higiene - 3);
  state.diversao = Math.min(100, state.diversao + 7);
  state.pesoExtra = Math.min(20, state.pesoExtra + 1);
  state.estresse = Math.max(0, state.estresse - 1);
  eating = true; eatFrame = 0;
  effect('🥞'); msg('PANQUECA! -30'); save();
  document.getElementById('foodMenu').classList.remove('active');
};
document.getElementById('foodMaca').onclick = () => {
  if (state.dinheiro < 25) { msg('SEM DINHEIRO!'); return; }
  if (state.fome > 95) { msg('CHEIO!'); return; }
  state.dinheiro -= 25;
  state.fome = Math.min(100, state.fome + 18);
  state.higiene = Math.max(0, state.higiene - 1);
  state.diversao = Math.min(100, state.diversao + 3);
  state.disciplina = Math.min(100, state.disciplina + 4);
  state.pesoExtra = Math.max(-10, state.pesoExtra - 0.5);
  state.estresse = Math.max(0, state.estresse - 4);
  eating = true; eatFrame = 0;
  effect('🍎'); msg('MAÇÃ! -25'); save();
  document.getElementById('foodMenu').classList.remove('active');
};

document.getElementById('btn2').onclick = () => {
  if (!state.vivo) return;
  window.playActionSound && window.playActionSound('sleep');
  state.dormindo = !state.dormindo;
  document.getElementById('sleepOverlay').classList.toggle('active', state.dormindo);
  msg(state.dormindo ? 'Zzz' : 'ACORDOU'); save();
};

document.getElementById('btn3').onclick = () => {
  if (!state.vivo || state.dormindo) return;
  window.playActionSound && window.playActionSound('bath');
  state.higiene = 100; state.sujo = false;
  document.getElementById('poop').style.display='none';
  for(let i=0;i<4;i++) setTimeout(()=>effect('💧'), i*120);
  state.disciplina = Math.min(100, state.disciplina + 8);
  state.estresse = Math.max(0, state.estresse - 4);
  msg('LIMPO!'); save();
};

document.getElementById('btn4').onclick = () => {
  if (!state.vivo || state.dormindo) return;
  window.playActionSound && window.playActionSound('play');
  document.getElementById('gameMenu').classList.add('active');
};

document.getElementById('btn5').onclick = () => {
  if (!state.vivo || state.dormindo) return;
  window.playActionSound && window.playActionSound('med');
  document.getElementById('medicineMenu').classList.add('active');
};

document.getElementById('btn6').onclick = () => {
  if (!state.vivo || state.dormindo) return;
  window.playActionSound && window.playActionSound('normal');
  document.getElementById('disciplineMenu').classList.add('active');
};
document.getElementById('discBack').onclick = () => {
  document.getElementById('disciplineMenu').classList.remove('active');
};
document.getElementById('discScold').onclick = () => {
  if (!state.vivo) return;
  state.disciplina = Math.min(100, state.disciplina + 15);
