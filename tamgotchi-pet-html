.effect { position:absolute; font-size:18px; pointer-events:none; animation: float 0.8s ease-out forwards; z-index:15; }
  @keyframes float { 0%{transform:translateY(0); opacity:1} 100%{transform:translateY(-30px); opacity:0} }
