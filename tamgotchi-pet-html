function startMathGame() {
  document.getElementById('gameMenu').classList.remove('active');
  const mg = document.getElementById('miniGame');
  mg.classList.add('active');
  
  // layout com pet do lado
  mg.innerHTML = `
    <div style="display:flex;height:100%;width:100%">
      <div style="width:38%;background:#6f9a3a;display:flex;align-items:center;justify-content:center;border-right:3px solid #1a2a0f;flex-direction:column">
